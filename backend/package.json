{
  "name": "contextboard-backend",
  "version": "0.1.0",
  "description": "Context Board backend API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main/bootstrap.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main/bootstrap.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --fileParallelism=false",
    "test:contract": "vitest run tests/contract --fileParallelism=false",
    "lint": "eslint src tests",
    "format": "prettier --write src tests"
  },
  "dependencies": {
    "express": "^5.0.1",
    "file-type": "^21.3.3",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "sharp": "^0.34.5",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild"
    ]
  }
}